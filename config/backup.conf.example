BACKUP_TARGET=placeholder-backupvault
WORKSPACE=workspace
STATE_DIR=state
LOG_DIR=logs
COLLECTOR_DIR=collectors
RESTORE_DIR=restore

ARCHIVE_PUBLIC_KEY=
RUNTIME_KEY=
SECRETS_FILE=

ENABLE_M365=true
ENABLE_CLOUDFLARE=true
ENABLE_NOTION=true

# Dedicated automation profile recommended
NOTION_PROFILE_DIR=/path/to/notion-profile
NOTION_PROFILE_NAME=Default
NOTION_BROWSER_EXECUTABLE=/usr/bin/microsoft-edge
NOTION_POLL_INTERVAL_SECONDS=60
NOTION_EXPORT_TIMEOUT_MINUTES=240
NOTION_WORKSPACE_URL=https://app.notion.com/
